---
import Layout from '../layouts/Layout.astro';
import ChapterNav from '../components/ChapterNav.astro';
import { mark13Sections } from '../data/mark13';
---

<Layout title="VIGIL • Mark 13 — The Olivet Discourse">
  <ChapterNav 
    current="MARK 13 — THE OLIVET DISCOURSE"
    prev={{ href: "/mark-12", label: "MARK 12" }}
  />

  <!-- Hero exactly matching the desired design -->
  <div class="relative h-[620px] flex items-center justify-center overflow-hidden border-b border-white/10">
    <div class="absolute inset-0">
      <img src="/images/temple-foretold.jpg" alt="The Olivet Discourse" 
           class="w-full h-full object-cover" style="filter: brightness(0.65) contrast(1.1);">
      <div class="absolute inset-0 bg-gradient-to-b from-black/60 via-black/50 to-black/70"></div>
    </div>

    <div class="relative z-10 text-center px-6">
      <div class="inline-flex items-center gap-x-2 px-4 py-1 rounded-full bg-black/40 border border-white/20 mb-6 text-sm">
        <div class="w-2 h-2 bg-[#5EEAD4] rounded-full"></div>
        <span class="tracking-[1.5px] text-[#5EEAD4]">ESV STUDY BIBLE • MARK 13:1–37</span>
      </div>

      <h1 class="heading-serif text-[72px] leading-[1.05] tracking-[-3px] text-white mb-3">
        The Olivet<br>Discourse
      </h1>
      <p class="text-2xl text-[#c8c8d0] tracking-tight">Jesus and the Coming Judgment</p>
    </div>
  </div>

  <!-- CORE THEME bar -->
  <div class="border-b border-white/10 bg-[#0a0a0f]">
    <div class="max-w-6xl mx-auto px-6 py-6">
      <div class="text-[#5EEAD4] text-sm tracking-widest font-medium">CORE THEME</div>
      <div class="text-2xl text-white mt-1">Preparedness. Readiness to suffer. Trust.</div>
    </div>
  </div>

  <!-- SUMMARY + CONTEXT cards -->
  <div class="app-container px-6 pt-10 pb-8">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
      <!-- SUMMARY Card -->
      <div class="glass rounded-3xl p-6">
        <div class="flex items-center gap-x-3 mb-4">
          <i class="fa-solid fa-align-left text-[#5EEAD4]"></i>
          <span class="text-sm font-semibold tracking-widest text-[#5EEAD4]">SUMMARY</span>
        </div>
        <p class="text-[#c8c8d0] leading-relaxed">
          Jesus leaves the Temple and prophesies its complete destruction, then from the Mount of Olives describes the coming tribulation, the abomination of desolation, and the return of the Son of Man in power and glory to gather the elect. He calls His disciples to remain watchful and to endure, anchoring their hope in the enduring authority of His words and the sovereign preservation of those the Father has chosen.
        </p>
      </div>

      <!-- CONTEXT Card -->
      <div class="glass rounded-3xl p-6">
        <div class="flex items-center gap-x-3 mb-4">
          <i class="fa-solid fa-globe text-[#6366f1]"></i>
          <span class="text-sm font-semibold tracking-widest text-[#6366f1]">CONTEXT</span>
        </div>
        <div class="space-y-2 text-sm text-[#c8c8d0]">
          <div><span class="font-medium text-white">Year:</span> c. A.D. 30 (Tuesday of Passion Week)</div>
          <div><span class="font-medium text-white">Location:</span> Mount of Olives, overlooking the Temple in Jerusalem (Judea)</div>
          <div><span class="font-medium text-white">People:</span> Jesus with the disciples, questioned privately by Peter, James, John & Andrew</div>
          <div><span class="font-medium text-white">In Jesus’ Life:</span> Final days before the crucifixion; His longest recorded teaching on the end times and His return in glory.</div>
        </div>
      </div>
    </div>
  </div>

  <!-- Sections Grid - Exact match to your reference image -->
  <div class="app-container px-6 pt-4 pb-20">
    <div class="mb-8">
      <span class="section-label text-[#5EEAD4]">SIX MOVEMENTS</span>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-6">
      <!-- Card 1 -->
      <div class="section-card group rounded-3xl overflow-hidden flex flex-col cursor-pointer h-full" data-section-id="1">
        <div class="relative h-44 overflow-hidden">
          <img src="/images/temple-foretold.jpg" class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-[1.06]" />
          <div class="absolute inset-0 bg-gradient-to-b from-black/30 via-black/40 to-black/70"></div>
          <div class="absolute top-4 left-4 z-10 w-8 h-8 rounded-2xl flex items-center justify-center text-sm font-mono font-semibold" style="background: rgba(10,10,15,0.75); color: #5EEAD4; border: 1px solid #5EEAD440">1</div>
          <div class="absolute top-4 left-[52px]">
            <div class="px-3 py-1 rounded-2xl text-[10px] font-bold tracking-[1.5px] flex items-center gap-x-1.5" style="background: rgba(94,234,212,0.13); color: #5EEAD4; border: 1px solid rgba(94,234,212,0.22)">
              <i class="fa-solid fa-landmark text-xs"></i>
              <span>THE TEMPLE FORETOLD</span>
            </div>
          </div>
          <div class="absolute bottom-4 right-4 text-right">
            <div class="font-mono text-xs text-white/60">13:1–2</div>
          </div>
        </div>
        <div class="p-5 flex-1 flex flex-col">
          <h3 class="font-semibold text-xl tracking-[-0.02em] leading-none mb-2.5 pr-2">Jesus Foretells the Destruction of the Temple</h3>
          <p class="text-[#a1a1aa] text-[13.5px] flex-1 leading-snug">As Jesus leaves the magnificent Temple, a disciple marvels at its stones. Jesus responds with a shocking prophecy.</p>
          <div class="mt-4 flex justify-end text-sm">
            <div class="text-[#5EEAD4] group-hover:translate-x-0.5 transition-transform">
              <i class="fa-solid fa-arrow-right"></i>
            </div>
          </div>
        </div>
      </div>

      <!-- Card 2 -->
      <div class="section-card group rounded-3xl overflow-hidden flex flex-col cursor-pointer h-full" data-section-id="2">
        <div class="relative h-44 overflow-hidden">
          <img src="/images/mount-of-olives.jpg" class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-[1.06]" />
          <div class="absolute inset-0 bg-gradient-to-b from-black/30 via-black/40 to-black/70"></div>
          <div class="absolute top-4 left-4 z-10 w-8 h-8 rounded-2xl flex items-center justify-center text-sm font-mono font-semibold" style="background: rgba(10,10,15,0.75); color: #5EEAD4; border: 1px solid #5EEAD440">2</div>
          <div class="absolute top-4 left-[52px]">
            <div class="px-3 py-1 rounded-2xl text-[10px] font-bold tracking-[1.5px] flex items-center gap-x-1.5" style="background: rgba(94,234,212,0.13); color: #5EEAD4; border: 1px solid rgba(94,234,212,0.22)">
              <i class="fa-solid fa-question-circle text-xs"></i>
              <span>THE QUESTION</span>
            </div>
          </div>
          <div class="absolute bottom-4 right-4 text-right">
            <div class="font-mono text-xs text-white/60">13:3–4</div>
          </div>
        </div>
        <div class="p-5 flex-1 flex flex-col">
          <h3 class="font-semibold text-xl tracking-[-0.02em] leading-none mb-2.5 pr-2">The Disciples Ask About the End</h3>
          <p class="text-[#a1a1aa] text-[13.5px] flex-1 leading-snug">On the Mount of Olives, with the Temple in view, Peter, James, John, and Andrew privately ask Jesus when these things will happen.</p>
          <div class="mt-4 flex justify-end text-sm">
            <div class="text-[#5EEAD4] group-hover:translate-x-0.5 transition-transform">
              <i class="fa-solid fa-arrow-right"></i>
            </div>
          </div>
        </div>
      </div>

      <!-- Card 3 -->
      <div class="section-card group rounded-3xl overflow-hidden flex flex-col cursor-pointer h-full" data-section-id="3">
        <div class="relative h-44 overflow-hidden">
          <img src="/images/persecution-witness.jpg" class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-[1.06]" />
          <div class="absolute inset-0 bg-gradient-to-b from-black/30 via-black/40 to-black/70"></div>
          <div class="absolute top-4 left-4 z-10 w-8 h-8 rounded-2xl flex items-center justify-center text-sm font-mono font-semibold" style="background: rgba(10,10,15,0.75); color: #5EEAD4; border: 1px solid #5EEAD440">3</div>
          <div class="absolute top-4 left-[52px]">
            <div class="px-3 py-1 rounded-2xl text-[10px] font-bold tracking-[1.5px] flex items-center gap-x-1.5" style="background: rgba(94,234,212,0.13); color: #5EEAD4; border: 1px solid rgba(94,234,212,0.22)">
              <i class="fa-solid fa-fire text-xs"></i>
              <span>BIRTH PAINS &amp; PERSECUTION</span>
            </div>
          </div>
          <div class="absolute bottom-4 right-4 text-right">
            <div class="font-mono text-xs text-white/60">13:5–13</div>
          </div>
        </div>
        <div class="p-5 flex-1 flex flex-col">
          <h3 class="font-semibold text-xl tracking-[-0.02em] leading-none mb-2.5 pr-2">Signs, Birth Pains &amp; Faithful Witness</h3>
          <p class="text-[#a1a1aa] text-[13.5px] flex-1 leading-snug">Jesus warns against being led astray, describes wars, earthquakes, and famines as the beginning of the birth pains.</p>
          <div class="mt-4 flex justify-end text-sm">
            <div class="text-[#5EEAD4] group-hover:translate-x-0.5 transition-transform">
              <i class="fa-solid fa-arrow-right"></i>
            </div>
          </div>
        </div>
      </div>

      <!-- Card 4 -->
      <div class="section-card group rounded-3xl overflow-hidden flex flex-col cursor-pointer h-full" data-section-id="4">
        <div class="relative h-44 overflow-hidden">
          <img src="/images/abomination.jpg" class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-[1.06]" />
          <div class="absolute inset-0 bg-gradient-to-b from-black/30 via-black/40 to-black/70"></div>
          <div class="absolute top-4 left-4 z-10 w-8 h-8 rounded-2xl flex items-center justify-center text-sm font-mono font-semibold" style="background: rgba(10,10,15,0.75); color: #5EEAD4; border: 1px solid #5EEAD440">4</div>
          <div class="absolute top-4 left-[52px]">
            <div class="px-3 py-1 rounded-2xl text-[10px] font-bold tracking-[1.5px] flex items-center gap-x-1.5" style="background: rgba(94,234,212,0.13); color: #5EEAD4; border: 1px solid rgba(94,234,212,0.22)">
              <i class="fa-solid fa-exclamation-triangle text-xs"></i>
              <span>THE ABOMINATION</span>
            </div>
          </div>
          <div class="absolute bottom-4 right-4 text-right">
            <div class="font-mono text-xs text-white/60">13:14–23</div>
          </div>
        </div>
        <div class="p-5 flex-1 flex flex-col">
          <h3 class="font-semibold text-xl tracking-[-0.02em] leading-none mb-2.5 pr-2">The Abomination of Desolation</h3>
          <p class="text-[#a1a1aa] text-[13.5px] flex-1 leading-snug">When the abomination of desolation stands where he ought not to be, those in Judea must flee without hesitation.</p>
          <div class="mt-4 flex justify-end text-sm">
            <div class="text-[#5EEAD4] group-hover:translate-x-0.5 transition-transform">
              <i class="fa-solid fa-arrow-right"></i>
            </div>
          </div>
        </div>
      </div>

      <!-- Card 5 -->
      <div class="section-card group rounded-3xl overflow-hidden flex flex-col cursor-pointer h-full" data-section-id="5">
        <div class="relative h-44 overflow-hidden">
          <img src="/images/son-of-man-coming.jpg" class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-[1.06]" />
          <div class="absolute inset-0 bg-gradient-to-b from-black/30 via-black/40 to-black/70"></div>
          <div class="absolute top-4 left-4 z-10 w-8 h-8 rounded-2xl flex items-center justify-center text-sm font-mono font-semibold" style="background: rgba(10,10,15,0.75); color: #5EEAD4; border: 1px solid #5EEAD440">5</div>
          <div class="absolute top-4 left-[52px]">
            <div class="px-3 py-1 rounded-2xl text-[10px] font-bold tracking-[1.5px] flex items-center gap-x-1.5" style="background: rgba(94,234,212,0.13); color: #5EEAD4; border: 1px solid rgba(94,234,212,0.22)">
              <i class="fa-solid fa-cloud-moon text-xs"></i>
              <span>THE SON OF MAN</span>
            </div>
          </div>
          <div class="absolute bottom-4 right-4 text-right">
            <div class="font-mono text-xs text-white/60">13:24–27</div>
          </div>
        </div>
        <div class="p-5 flex-1 flex flex-col">
          <h3 class="font-semibold text-xl tracking-[-0.02em] leading-none mb-2.5 pr-2">The Coming of the Son of Man</h3>
          <p class="text-[#a1a1aa] text-[13.5px] flex-1 leading-snug">After that tribulation, cosmic signs will appear. Then the Son of Man will come in clouds with great power and glory.</p>
          <div class="mt-4 flex justify-end text-sm">
            <div class="text-[#5EEAD4] group-hover:translate-x-0.5 transition-transform">
              <i class="fa-solid fa-arrow-right"></i>
            </div>
          </div>
        </div>
      </div>

      <!-- Card 6 -->
      <div class="section-card group rounded-3xl overflow-hidden flex flex-col cursor-pointer h-full" data-section-id="6">
        <div class="relative h-44 overflow-hidden">
          <img src="/images/watchful-servant.jpg" class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-[1.06]" />
          <div class="absolute inset-0 bg-gradient-to-b from-black/30 via-black/40 to-black/70"></div>
          <div class="absolute top-4 left-4 z-10 w-8 h-8 rounded-2xl flex items-center justify-center text-sm font-mono font-semibold" style="background: rgba(10,10,15,0.75); color: #5EEAD4; border: 1px solid #5EEAD440">6</div>
          <div class="absolute top-4 left-[52px]">
            <div class="px-3 py-1 rounded-2xl text-[10px] font-bold tracking-[1.5px] flex items-center gap-x-1.5" style="background: rgba(94,234,212,0.13); color: #5EEAD4; border: 1px solid rgba(94,234,212,0.22)">
              <i class="fa-solid fa-clock text-xs"></i>
              <span>WATCH &amp; STAY AWAKE</span>
            </div>
          </div>
          <div class="absolute bottom-4 right-4 text-right">
            <div class="font-mono text-xs text-white/60">13:28–37</div>
          </div>
        </div>
        <div class="p-5 flex-1 flex flex-col">
          <h3 class="font-semibold text-xl tracking-[-0.02em] leading-none mb-2.5 pr-2">The Lesson of the Fig Tree &amp; The Call to Vigilance</h3>
          <p class="text-[#a1a1aa] text-[13.5px] flex-1 leading-snug">Learn from the fig tree. No one knows the day or hour. Therefore, stay awake.</p>
          <div class="mt-4 flex justify-end text-sm">
            <div class="text-[#5EEAD4] group-hover:translate-x-0.5 transition-transform">
              <i class="fa-solid fa-arrow-right"></i>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Deep Dive Modal -->
  <div id="deep-dive-modal" class="hidden fixed inset-0 bg-black/90 backdrop-blur-md z-[70] flex items-center justify-center p-4 md:p-8">
    <div class="modal w-full max-w-[1100px] bg-[#121217] border border-white/10 rounded-3xl overflow-hidden shadow-2xl max-h-[94vh] flex flex-col">
      
      <div class="px-8 pt-7 pb-6 flex items-center justify-between border-b border-white/10 flex-shrink-0">
        <div id="modal-header" class="flex items-center gap-x-4"></div>
        <button onclick="closeModal()" class="text-3xl leading-none text-white/40 hover:text-white transition-colors w-9 h-9 flex items-center justify-center">&times;</button>
      </div>

      <div class="flex-1 overflow-y-auto">
        <div id="modal-hero" class="relative h-[360px] w-full"></div>

        <div class="px-8 pt-8 pb-12 grid md:grid-cols-12 gap-x-8 gap-y-8">
          <div class="md:col-span-7">
            <div class="flex items-center gap-x-3 mb-4">
              <i class="fa-solid fa-book-open text-[#5EEAD4]"></i>
              <span class="section-label tracking-[1.5px]">THE TEXT</span>
            </div>
            <div id="modal-scripture" class="scripture-text text-[#e5e5e7] leading-relaxed pr-1"></div>
          </div>

          <div class="md:col-span-5 space-y-8">
            <div>
              <div class="flex items-center gap-x-3 mb-4">
                <i class="fa-solid fa-pen-fancy text-[#6366f1]"></i>
                <span class="section-label tracking-[1.5px]">STUDY COMMENTARY</span>
              </div>
              <div id="modal-commentary" class="commentary-block p-5 text-[15px] leading-snug text-[#c8c8d0] rounded-r-2xl"></div>
            </div>

            <div>
              <div class="flex items-center gap-x-3 mb-4">
                <i class="fa-solid fa-book text-[#34d3c1]"></i>
                <span class="section-label tracking-[1.5px]">FROM THE ESV COMMENTARY</span>
              </div>
              <div id="modal-key-truths" class="space-y-2"></div>
            </div>
          </div>

          <!-- Reflection -->
          <div class="md:col-span-12 mt-4 pt-6 border-t border-white/10">
            <div class="glass p-6 rounded-3xl">
              <div class="uppercase text-xs tracking-widest mb-2 text-[#34d3c1]">FOR MEDITATION</div>
              <div id="modal-reflection" class="text-lg text-[#e5e5e7]"></div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <script>
    import { mark13Sections } from '../data/mark13';

    const modal = document.getElementById('deep-dive-modal');
    const cards = document.querySelectorAll('[data-section-id]');

    cards.forEach(card => {
      card.addEventListener('click', () => {
        const id = parseInt(card.dataset.sectionId);
        const section = mark13Sections.find(s => s.id === id);
        if (!section) return;

        // Header
        document.getElementById('modal-header').innerHTML = `
          <div style="color: ${section.color}" class="text-4xl"><i class="${section.icon}"></i></div>
          <div>
            <div class="uppercase tracking-[2px] text-xs font-semibold" style="color: ${section.color}">${section.label}</div>
            <div class="text-3xl font-semibold tracking-[-0.02em] mt-px">${section.title}</div>
            <div class="font-mono text-xs mt-1 text-[#a1a1aa]">${section.verseRange}</div>
          </div>
        `;

        // Hero
        document.getElementById('modal-hero').innerHTML = `
          <div class="relative h-full w-full">
            <img src="${section.image}" alt="${section.title}" class="w-full h-full object-cover">
            <div class="absolute inset-0 bg-gradient-to-b from-transparent via-[#121217]/70 to-[#121217]"></div>
          </div>
        `;

        // Scripture
        document.getElementById('modal-scripture').innerHTML = section.scripture;

        // Commentary
        document.getElementById('modal-commentary').innerHTML = `<p>${section.commentary}</p>`;

        // Key Truths
        const truthsHtml = section.keyTruths.map(t => `
          <div class="flex items-start gap-3 p-3 bg-[#1a1a22] hover:bg-[#202028] rounded-2xl border border-white/5">
            <div class="mt-1 w-5 h-5 flex-shrink-0 rounded-xl flex items-center justify-center" style="background: #5EEAD422">
              <i class="fa-solid fa-check text-xs" style="color: #5EEAD4"></i>
            </div>
            <div class="text-sm leading-tight text-[#c8c8d0]">${t}</div>
          </div>
        `).join('');
        document.getElementById('modal-key-truths').innerHTML = truthsHtml;

        // Reflection
        document.getElementById('modal-reflection').innerHTML = section.reflection || '';

        modal.classList.remove('hidden');
        modal.classList.add('flex');
      });
    });

    window.closeModal = () => {
      modal.classList.remove('flex');
      modal.classList.add('hidden');
    };

    // Close on escape
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && !modal.classList.contains('hidden')) {
        window.closeModal();
      }
    });
  </script>
</Layout>