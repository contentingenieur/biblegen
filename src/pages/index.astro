---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Mark • Illustrated">
  <!-- Rich Hero matching the dramatic illustrated style of the chapters -->
  <div class="relative h-[620px] flex items-center justify-center overflow-hidden border-b border-white/10">
    <div class="absolute inset-0">
      <img src="/images/temple-foretold.jpg" alt="The Gospel of Mark" 
           class="w-full h-full object-cover" style="filter: brightness(0.52) contrast(1.25) saturate(0.9);">
      <div class="absolute inset-0 bg-gradient-to-b from-black/55 via-black/40 to-black/90"></div>
    </div>

    <div class="app-container px-6 relative z-10 text-center">
      <div class="inline-flex items-center gap-x-2 px-4 py-1 rounded-full bg-black/40 border border-white/20 mb-6 text-sm">
        <div class="w-2 h-2 bg-[#5EEAD4] rounded-full"></div>
        <span class="tracking-[1.5px] text-[#5EEAD4]">ESV STUDY BIBLE • THE GOSPEL OF MARK</span>
      </div>

      <h1 class="heading-serif text-[72px] leading-[1.05] tracking-[-3px] text-white mb-3">
        The Gospel of Mark
      </h1>
      <p class="max-w-md mx-auto text-2xl text-[#c8c8d0] tracking-tight">An illustrated, contemplative reading experience</p>
    </div>
  </div>

  <div class="max-w-6xl mx-auto px-6 pt-12 pb-20">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
      <!-- Mark 12 Card -->
      <a href="/mark-12" class="chapter-card group rounded-3xl overflow-hidden block relative" style="min-height: 320px;">
        <img src="/images/temple-foretold.jpg" alt="Mark 12" class="absolute inset-0 w-full h-full object-cover transition-transform duration-700 group-hover:scale-[1.04]" />
        <div class="absolute inset-0 bg-gradient-to-b from-black/35 via-black/55 to-black/85"></div>
        <div class="relative p-8 flex flex-col h-full">
          <div>
            <div class="text-[#5EEAD4] text-sm font-semibold tracking-[2px]">CHAPTER 12</div>
            <h2 class="heading-serif text-4xl mt-2 tracking-[-0.02em] text-white">Questions in the Temple</h2>
          </div>
          <div class="flex-1"></div>
          <div class="mt-4 flex items-center text-[#5EEAD4] font-medium">
            <span>Enter Chapter</span>
            <i class="fa-solid fa-arrow-right ml-3 transition group-hover:translate-x-1"></i>
          </div>
        </div>
      </a>

      <!-- Mark 13 Card -->
      <a href="/mark-13" class="chapter-card group rounded-3xl overflow-hidden block relative" style="min-height: 320px;">
        <img src="/images/son-of-man-coming.jpg" alt="Mark 13" class="absolute inset-0 w-full h-full object-cover transition-transform duration-700 group-hover:scale-[1.04]" />
        <div class="absolute inset-0 bg-gradient-to-b from-black/35 via-black/55 to-black/85"></div>
        <div class="relative p-8 flex flex-col h-full">
          <div>
            <div class="text-[#5EEAD4] text-sm font-semibold tracking-[2px]">CHAPTER 13</div>
            <h2 class="heading-serif text-4xl mt-2 tracking-[-0.02em] text-white">The Olivet Discourse</h2>
          </div>
          <div class="flex-1"></div>
          <div class="mt-4 flex items-center text-[#5EEAD4] font-medium">
            <span>Enter Chapter</span>
            <i class="fa-solid fa-arrow-right ml-3 transition group-hover:translate-x-1"></i>
          </div>
        </div>
      </a>
    </div>

    <div class="mt-12 text-center text-sm text-[#666]">
      The first two chapters • More of the New Testament coming soon • Designed for slow, beautiful, gospel-centered reading
    </div>
  </div>
</Layout>