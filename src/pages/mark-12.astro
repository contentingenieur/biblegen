---
import Layout from '../layouts/Layout.astro';
import ChapterNav from '../components/ChapterNav.astro';
import { mark12Sections } from '../data/mark12';
---

<Layout title="VIGIL • Mark 12 — Questions in the Temple">
  <ChapterNav 
    current="MARK 12 — QUESTIONS IN THE TEMPLE"
    next={{ href: "/mark-13", label: "MARK 13" }}
  />

  <div class="relative h-[520px] flex items-center justify-center overflow-hidden border-b border-white/10">
    <div class="absolute inset-0 bg-gradient-to-b from-[#0a0a0f] via-[#0a0a0f]/80 to-[#0a0a0f]"></div>
    <div class="app-container px-6 relative z-10 text-center">
      <h1 class="heading-serif text-6xl tracking-[-0.03em] leading-none mb-3">Questions in the Temple</h1>
      <p class="max-w-lg mx-auto text-xl text-[#a1a1aa]">Jesus teaches with parables and wisdom in the final days before the cross.</p>
    </div>
  </div>

  <div class="app-container px-6 pt-10 pb-20">
    <div class="mb-8">
      <span class="section-label text-[#5EEAD4]">SIX MOVEMENTS</span>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-6">
      {mark12Sections.map((section, index) => (
        <div class="section-card group rounded-3xl overflow-hidden flex flex-col cursor-pointer h-full" data-section-id={section.id}>
          <div class="relative h-44 overflow-hidden">
            <img src={section.image} alt={section.title} class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-[1.06]" />
            <div class="absolute inset-0 bg-gradient-to-b from-black/30 via-black/40 to-black/70"></div>
            
            <div class="absolute top-4 left-4 z-10 w-8 h-8 rounded-2xl flex items-center justify-center text-sm font-mono font-semibold"
                 style={`background: rgba(10,10,15,0.75); color: ${section.color}; border: 1px solid ${section.color}40`}>
              {index + 1}
            </div>

            <div class="absolute top-4 left-[52px]">
              <div class="px-3 py-1 rounded-2xl text-[10px] font-bold tracking-[1.5px] flex items-center gap-x-1.5"
                   style="background: rgba(94,234,212,0.13); color: #5EEAD4; border: 1px solid rgba(94,234,212,0.22)">
                <i class={section.icon + " text-xs"}></i>
                <span>{section.label}</span>
              </div>
            </div>
          </div>

          <div class="p-5 flex-1 flex flex-col">
            <h3 class="font-semibold text-xl tracking-[-0.02em] leading-none mb-2.5 pr-2">{section.title}</h3>
            <p class="text-[#a1a1aa] text-[13.5px] flex-1 leading-snug">{section.summary}</p>
            
            <div class="mt-4 flex justify-end text-sm">
              <div class="text-[#5EEAD4] group-hover:translate-x-0.5 transition-transform">
                <i class="fa-solid fa-arrow-right"></i>
              </div>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>

  <div class="app-container px-6 pb-12 text-center text-[#a1a1aa]">
    <p>Full interactive experience for Mark 12 is being ported. The structure is ready.</p>
  </div>
</Layout>