---
interface Props {
  title: string;
  description?: string;
}

const { title, description = "An illustrated, contemplative reading experience of the Gospel of Mark" } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <meta name="description" content={description} />
    
    <!-- Tailwind via CDN for fast migration -->
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
    
    <style>
      @import url('https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600&family=Playfair+Display:wght@700&display=swap');

      :root {
        --teal: #5EEAD4;
      }

      body {
        background-color: #0a0a0f;
        color: #f5f5f7;
        font-family: 'Inter', system_ui, sans-serif;
      }

      .heading-serif {
        font-family: 'Playfair Display', Georgia, serif;
        font-weight: 700;
        letter-spacing: -0.02em;
      }

      .app-container {
        max-width: 1280px;
        margin: 0 auto;
      }

      .section-label {
        font-size: 0.7rem;
        letter-spacing: 1.5px;
        text-transform: uppercase;
        font-weight: 600;
      }

      /* === Exact styles from your original beautiful HTML === */
      .section-card {
        transition: all 0.4s cubic-bezier(0.23, 1, 0.32, 1);
        background: linear-gradient(145deg, #121217 0%, #1a1a22 100%);
        border: 1px solid rgba(94, 234, 212, 0.08);
      }
      .section-card:hover {
        transform: translateY(-4px);
        border-color: rgba(94, 234, 212, 0.25);
        box-shadow: 0 25px 50px -12px rgb(0 0 0 / 0.4);
      }

      .chapter-card {
        transition: all 0.4s cubic-bezier(0.23, 1, 0.32, 1);
        background: linear-gradient(145deg, #121217 0%, #1a1a22 100%);
        border: 1px solid rgba(94, 234, 212, 0.1);
      }
      .chapter-card:hover {
        transform: translateY(-6px);
        border-color: rgba(94, 234, 212, 0.3);
        box-shadow: 0 25px 50px -12px rgb(0 0 0 / 0.4);
      }

      .modal {
        animation: modalEnter 0.4s cubic-bezier(0.23, 1, 0.32, 1);
      }
      @keyframes modalEnter {
        from { opacity: 0; transform: translateY(40px) scale(0.985); }
        to { opacity: 1; transform: translateY(0) scale(1); }
      }

      .scripture-text { font-size: 1.02rem; line-height: 1.75; }
      .verse-num { color: #5EEAD4; font-weight: 600; font-size: 0.75rem; vertical-align: super; margin-right: 4px; }

      .commentary-block {
        border-left: 3px solid #5EEAD4;
        background: rgba(94, 234, 212, 0.035);
      }

      .visual-frame { position: relative; overflow: hidden; }
      .visual-frame::after {
        content: '';
        position: absolute;
        inset: 0;
        background: linear-gradient(to bottom, rgba(10,10,15,0.18) 0%, transparent 18%),
                    linear-gradient(to top, rgba(10,10,15,0.10) 0%, transparent 12%);
        pointer-events: none;
      }

      .key-truth {
        transition: transform 0.2s ease, box-shadow 0.2s ease;
      }
      .key-truth:hover { transform: translateX(4px); }

      .glass {
        background: rgba(26, 26, 34, 0.8);
        backdrop-filter: blur(20px);
        border: 1px solid rgba(94, 234, 212, 0.1);
      }
    </style>
  </head>
  <body class="antialiased">
    <!-- Main VIGIL Header (matching original design) -->
    <nav class="sticky top-0 z-50 border-b border-white/10 bg-[#0a0a0f]/95 backdrop-blur-xl">
      <div class="app-container max-w-7xl mx-auto px-6 h-16 flex items-center justify-between">
        <div class="flex items-center gap-x-3">
          <div class="w-9 h-9 rounded-2xl bg-gradient-to-br from-[#5EEAD4] via-[#4BC4B0] to-[#5EEAD4] flex items-center justify-center shadow-lg shadow-[#5EEAD4]/20">
            <i class="fa-solid fa-eye text-[#0a0a0f] text-xl"></i>
          </div>
          <div>
            <div class="font-semibold text-2xl tracking-[-0.04em] leading-none">VIGIL</div>
            <div class="text-[10px] text-[#a1a1aa] -mt-0.5">MARK</div>
          </div>
        </div>

        <div class="flex items-center gap-x-3">
          <button onclick="showFullScripture()" 
                  class="w-9 h-9 flex items-center justify-center border border-white/15 hover:bg-white/5 hover:border-white/30 rounded-2xl transition-colors text-[#a1a1aa] hover:text-white"
                  title="Full Scripture">
            <i class="fa-solid fa-book text-sm"></i>
          </button>
        </div>
      </div>
    </nav>

    <slot />

    <footer class="border-t border-white/10 bg-[#0a0a0f]">
      <div class="max-w-6xl mx-auto px-6 py-8 text-xs text-[#666] flex flex-col md:flex-row md:items-center md:justify-between gap-y-2">
        <div>ESV Study Bible • Illustrated Reading Experience</div>
        <div>Built with Astro • Designed for slow, contemplative reading</div>
      </div>
    </footer>

    <script>
      // Placeholder for full scripture modal if needed
      window.showFullScripture = () => {
        alert('Full Scripture view coming soon in this Astro version');
      };
    </script>
  </body>
</html>