---
interface Props {
  title: string;
  description?: string;
}

const { title, description = "An illustrated, contemplative reading experience of the Gospel of Mark" } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <meta name="description" content={description} />
    
    <!-- Tailwind via CDN for fast migration -->
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
    
    <style>
      @import url('https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600&family=Playfair+Display:wght@700&display=swap');

      body {
        background-color: #0a0a0f;
        color: #f5f5f7;
        font-family: 'Inter', system_ui, sans-serif;
      }

      .heading-serif {
        font-family: 'Playfair Display', Georgia, serif;
        font-weight: 700;
        letter-spacing: -0.02em;
      }

      .section-card {
        transition: all 0.4s cubic-bezier(0.23, 1, 0.32, 1);
        background: linear-gradient(145deg, #121217 0%, #1a1a22 100%);
        border: 1px solid rgba(94, 234, 212, 0.08);
      }

      .section-card:hover {
        transform: translateY(-4px);
        border-color: rgba(94, 234, 212, 0.25);
        box-shadow: 0 25px 50px -12px rgb(0 0 0 / 0.4);
      }

      .modal {
        animation: modalEnter 0.4s cubic-bezier(0.23, 1, 0.32, 1);
      }

      @keyframes modalEnter {
        from { opacity: 0; transform: translateY(40px) scale(0.985); }
        to { opacity: 1; transform: translateY(0) scale(1); }
      }

      .scripture-text { font-size: 1.02rem; line-height: 1.75; }
      .verse-num { color: #5EEAD4; font-weight: 600; font-size: 0.75rem; vertical-align: super; margin-right: 4px; }

      .commentary-block {
        border-left: 3px solid #5EEAD4;
        background: rgba(94, 234, 212, 0.035);
      }

      .app-container { max-width: 1280px; margin: 0 auto; }
      .section-label { font-size: 0.7rem; letter-spacing: 1.5px; text-transform: uppercase; font-weight: 600; }
    </style>
  </head>
  <body class="antialiased">
    <slot />

    <footer class="border-t border-white/10 bg-[#0a0a0f]">
      <div class="max-w-6xl mx-auto px-6 py-8 text-xs text-[#666] flex flex-col md:flex-row md:items-center md:justify-between gap-y-2">
        <div>ESV Study Bible • Illustrated Reading Experience</div>
        <div>Built with Astro • Designed for slow, contemplative reading</div>
      </div>
    </footer>
  </body>
</html>